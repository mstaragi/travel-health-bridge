{
  "name": "travel-health-bridge",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run consumer:web\" \"npm run provider:web\" \"npm run admin:dev\"",
    "consumer:web": "cmd /c \"npm.cmd --prefix apps/consumer run web -- --port 8081\"",
    "provider:web": "cmd /c \"npm.cmd --prefix apps/provider run web -- --port 8082 --host localhost\"",
    "admin:dev": "cmd /c \"npm.cmd --prefix apps/admin run dev -- -p 3000\"",
    "build:provider": "npm run build --prefix apps/provider",
    "build:admin": "npm run build --prefix apps/admin",
    "test": "node tests/test-rank-providers.js"
  },
  "devDependencies": {
    "babel-plugin-module-resolver": "^5.0.3",
    "concurrently": "^8.2.2"
  }
}
