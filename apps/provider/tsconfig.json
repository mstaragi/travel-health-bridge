{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@travelhealthbridge/shared": [
        "../../packages/shared/index.ts"
      ],
      "store": ["./app/store"],
      "store/*": ["./app/store/*"],
      "lib": ["./app/lib"],
      "lib/*": ["./app/lib/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
