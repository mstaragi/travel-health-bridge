{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "paths": {
      "@travelhealthbridge/shared": [
        "../../packages/shared/index.ts"
      ],
      "db": ["./db"],
      "db/*": ["./db/*"],
      "lib": ["./lib"],
      "lib/*": ["./lib/*"],
      "store": ["./app/store"],
      "store/*": ["./app/store/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
