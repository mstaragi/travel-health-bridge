# Travel Health Bridge — Environment Variables Template
# Copy this file to .env.local in the root directory and fill in your credentials.
# Different apps use different subsets of these variables.

# ─ Supabase (Required for ALL apps) ────────────────────────────────────────────
# Get these from your Supabase project: https://app.supabase.com
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─ Admin Console ONLY (apps/admin) ────────────────────────────────────────────
# Service role key for server-side admin queries (NEVER expose to client).
# Get this from: https://app.supabase.com → Settings → API → Service role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─ Maps & Location (Consumer app ONLY) ────────────────────────────────────────
# Google Maps API key for directions and provider location display.
# Create at: https://console.cloud.google.com/apis/credentials
EXPO_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-key-here

# ─ Error Tracking (All apps) ──────────────────────────────────────────────────
# Sentry for native crash reporting (consumer app).
# Get from: https://sentry.io → Settings → Client Keys
EXPO_PUBLIC_SENTRY_DSN=your-sentry-dsn-here

# ─ Analytics (All apps) ───────────────────────────────────────────────────────
# PostHog API key for event tracking and analytics.
# Get from: https://posthog.com → Settings → Project API key
EXPO_PUBLIC_POSTHOG_API_KEY=your-posthog-api-key-here
EXPO_PUBLIC_POSTHOG_API_HOST=https://app.posthog.com

# ─ Build & Deployment ────────────────────────────────────────────────────────
# App environment: 'development', 'staging', or 'production'
EXPO_PUBLIC_APP_ENV=development

# Vercel deployment URLs (auto-set by Vercel, manual here if needed)
# NEXT_PUBLIC_PROVIDER_PWA_URL=https://providers.travelhealthbridge.com
# NEXT_PUBLIC_ADMIN_URL=https://admin.travelhealthbridge.com

# ─ EAS Build (Consumer app ONLY) ─────────────────────────────────────────────
# EAS credentials for building native binaries.
# Obtain from: eas build:configure
EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id-here

# ─ Firebase (App Store metadata + Cloud Messaging) ──────────────────────────
# For push notifications on Android.
# Download from Firebase Console: https://console.firebase.google.com
# Note: This is typically configured via google-services.json files, not env vars.
# Keeping here for reference.
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id-here
EXPO_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key-here
